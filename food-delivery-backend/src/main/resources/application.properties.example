# Copy this file to application.properties and fill in your values.
# application.properties is gitignored — never commit it.

spring.application.name=food_delivery

spring.datasource.url=jdbc:postgresql://localhost:5432/FoodDelivery
spring.datasource.username=postgres
spring.datasource.password=your_db_password_here

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false

recommendation.api.advanced-url=http://localhost:5002
sentiment.api.base-url=http://localhost:5002
rfm.api.base-url=http://localhost:5002

app.seed.enabled=false

# JWT — generate a strong random secret (e.g. openssl rand -hex 32)
app.jwt.secret=your_jwt_secret_here
app.jwt.expiration=864000000

# Stripe — get keys from https://dashboard.stripe.com/test/apikeys
stripe.secret-key=sk_test_your_secret_key_here
stripe.publishable-key=pk_test_your_publishable_key_here
